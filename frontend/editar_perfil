<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Perfil</title>
    <style>
        body {
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: linear-gradient(135deg, #1b5e20, #004d40);
            font-family: 'Roboto', sans-serif;
            color: #333;
            animation: fadeIn 1s ease-in-out;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }
        .container {
            width: 90%;
            max-width: 400px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
            max-height: 90%;
            overflow-y: auto;
            animation: popIn 0.5s ease;
        }
        @keyframes popIn {
            from {
                transform: scale(0.9);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }
        .title {
            font-size: 1.8rem;
            font-weight: bold;
            margin-bottom: 1rem;
            color: #2c3e50;
            text-align: center;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
        }
        .form-group {
            margin-bottom: 1rem;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
        }
        .form-group label {
            flex: 1 1 40%;
            font-size: 1rem;
            font-weight: bold;
            margin-bottom: 0.5rem;
            color: #555;
        }
        .form-group input {
            flex: 1 1 55%;
            padding: 10px;
            font-size: 1rem;
            border: 1px solid #ccc;
            border-radius: 8px;
            box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.1);
        }
        .button-container {
            display: flex;
            justify-content: space-between;
            margin-top: 1.5rem;
        }
        .button, .back-button {
            flex: 1 1 48%;
            margin: 0 1%;
            padding: 10px 20px;
            font-size: 1rem;
            font-weight: bold;
            color: #fff;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.2s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .button {
            background-color: #3498db;
        }
        .button:hover {
            background-color: #2980b9;
            transform: scale(1.05);
        }
        .back-button {
            background-color: #e74c3c;
        }
        .back-button:hover {
            background-color: #c0392b;
            transform: scale(1.05);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="title" id="profile-title">Perfil</div>
        <form id="profile-form">
            <div class="form-group">
                <label for="username">Nombre de Usuario:</label>
                <input type="text" id="username" name="username">
            </div>
            <div class="form-group">
                <label for="full-name">Nombre Completo:</label>
                <input type="text" id="full-name" name="full-name">
            </div>
            <div class="form-group">
                <label for="email">Correo Electrónico:</label>
                <input type="email" id="email" name="email">
            </div>
            <div class="form-group">
                <label for="dni">DNI:</label>
                <input type="text" id="dni" name="dni">
            </div>
            <div class="form-group">
                <label for="address">Dirección (Población):</label>
                <input type="text" id="address" name="address">
            </div>
            <div class="form-group">
                <label for="phone">Número de Teléfono:</label>
                <input type="text" id="phone" name="phone">
            </div>
            <div class="form-group">
                <label for="km">Kilómetros hasta el Club:</label>
                <input type="number" id="km" name="km">
            </div>
            <div class="form-group">
                <label for="club-code">Código del Club:</label>
                <input type="text" id="club-code" name="club-code" readonly>
            </div>
            <div class="form-group">
                <label for="role">Rol:</label>
                <input type="text" id="role" name="role" readonly>
            </div>
            <div class="button-container">
                <button type="button" class="back-button" onclick="window.location.href=`interfaz_personalizada.html?nombre=${encodeURIComponent(document.getElementById('username').value)}`">Atrás</button>
                <button type="button" class="button" onclick="saveProfile()">Guardar</button>
            </div>
        </form>
    </div>
    <script>
        const params = new URLSearchParams(window.location.search);
        const username = params.get('nombre'); // Get the username from the query parameter
        const referrer = params.get('referrer'); // Get the referrer page

        if (!username) {
            alert('Error: Usuario no identificado.');
            window.location.href = 'inicio_app1.html'; // Redirect to the main page
        }

        const userData = JSON.parse(localStorage.getItem(username)) || {};

        document.getElementById('profile-title').textContent = `Perfil: ${username}`;
        document.getElementById('username').value = username || '';
        document.getElementById('full-name').value = userData.fullName || '';
        document.getElementById('email').value = userData.email || '';
        document.getElementById('dni').value = userData.dni || '';
        document.getElementById('address').value = userData.address || '';
        document.getElementById('phone').value = userData.phone || '';
        document.getElementById('km').value = userData.km || '';
        document.getElementById('club-code').value = userData.clubCode || ''; // Display club code
        document.getElementById('role').value = userData.role || ''; // Display role

        // Make username field readonly unless referrer is "ver_usuarios"
        if (referrer !== 'ver_usuarios') {
            document.getElementById('username').readOnly = true;
        }

        function saveProfile() {
            const newUsername = document.getElementById('username').value.trim();
            if (!newUsername) {
                alert('El nombre de usuario no puede estar vacío.');
                return;
            }

            if (newUsername !== username && localStorage.getItem(newUsername)) {
                alert('El nuevo nombre de usuario ya existe. Por favor, elige otro.');
                return;
            }

            const updatedData = {
                ...userData,
                username: newUsername,
                fullName: document.getElementById('full-name').value,
                email: document.getElementById('email').value,
                dni: document.getElementById('dni').value,
                address: document.getElementById('address').value,
                phone: document.getElementById('phone').value,
                km: document.getElementById('km').value,
            };

            if (newUsername !== username) {
                localStorage.removeItem(username); // Remove old username
            }
            localStorage.setItem(newUsername, JSON.stringify(updatedData)); // Save with new username
            alert('Perfil guardado exitosamente.');

            // Notify gestion_usuarios.html to refresh the table
            if (window.opener && !window.opener.closed) {
                window.opener.loadUsers?.(); // Call loadUsers if available in the parent window
            }

            // Redirect to the updated profile page
            window.location.href = `editar_perfil.html?nombre=${encodeURIComponent(newUsername)}`;
        }

        document.querySelector('.back-button').onclick = function() {
            if (referrer === 'gestion_usuarios') {
                window.location.href = 'gestion_usuarios.html';
            } else if (referrer === 'ver_usuarios') {
                window.location.href = 'ver_usuarios.html';
            } else {
                window.location.href = `interfaz_personalizada.html?nombre=${encodeURIComponent(username)}`;
            }
        };
    </script>
</body>
</html>
